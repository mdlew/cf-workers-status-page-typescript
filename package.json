{
  "name": "cf-worker-status-page-typescript",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "public:assets": "tsx ./scripts/public-assets.ts",
    "build": "pnpm run wrangler:types && tsc && pnpm run public:assets && vike build",
    "preview": "pnpm run build && wrangler dev",
    "preview:production": "pnpm run build && wrangler dev --env production",
    "deploy": "pnpm run build && wrangler deploy --env production",
    "prepare": "husky",
    "wrangler:types": "wrangler types",
    "postinstall": "pnpm run public:assets"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.5.0",
    "@floating-ui/react": "^0.27.19",
    "clsx": "^2.1.1",
    "papaparse": "^5.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-streaming": "^0.4.20",
    "vike": "^0.4.259"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@commitlint/config-conventional": "^21.0.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "commitlint": "^21.0.2",
    "dedent": "^1.7.2",
    "husky": "^9.1.7",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "^8.0.16",
    "wrangler": "latest"
  }
}
