{
  "name": "cf-worker-status-page-typescript",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "public:assets": "tsx ./scripts/public-assets.ts",
    "build": "pnpm run wrangler:types && tsc && pnpm run public:assets && vike build",
    "preview": "pnpm run build && wrangler dev",
    "preview:production": "pnpm run build && wrangler dev --env production",
    "deploy": "pnpm run build && wrangler deploy --env production",
    "prepare": "husky",
    "wrangler:types": "wrangler types",
    "postinstall": "pnpm run public:assets"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.4.2",
    "@floating-ui/react": "^0.27.19",
    "clsx": "^2.1.1",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-streaming": "^0.4.17",
    "vike": "^0.4.256"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260413.1",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "commitlint": "^20.5.0",
    "dedent": "^1.7.2",
    "husky": "^9.1.7",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "^8.0.8",
    "wrangler": "latest"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^10.2.2"
    }
  }
}